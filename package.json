{
  "name": "agent-sdlc",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-oriented SDLC platform baseline",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "task-gateway": "node scripts/task-gateway.js",
    "task-gateway:example": "node scripts/task-gateway.js normalize-gitea-issue-comment --event docs/examples/gitea-issue-comment-event.example.json",
    "agent-control": "node scripts/agent-control.js",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "validate:platform": "node --check scripts/task-gateway.js && node --check scripts/agent-control.js && node --check scripts/lib/simple-yaml.js && node --check scripts/lib/policy-loader.js && node --check scripts/lib/project-state.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
